<view class="house-binding-page"><view class="content"><view class="form-section"><view class="form-item"><text class="label">真实姓名</text><input class="input" type="text" placeholder="请输入真实姓名" maxlength="20" data-event-opts="{{[['input',[['__set_model',['$0','realName','$event',[]],['formData']]]]]}}" value="{{formData.realName}}" bindinput="__e"/></view><view class="form-item"><text class="label">手机号</text><input class="input" type="number" placeholder="请输入手机号" maxlength="11" data-event-opts="{{[['input',[['__set_model',['$0','phone','$event',[]],['formData']]]]]}}" value="{{formData.phone}}" bindinput="__e"/></view><view class="form-item"><text class="label">性别</text><picker value="{{genderIndex}}" range="{{genderList}}" range-key="name" data-event-opts="{{[['change',[['onGenderChange',['$event']]]]]}}" bindchange="__e"><view class="picker-content"><text class="{{['picker-text',(genderIndex===null)?'placeholder':'']}}">{{''+(genderIndex!==null?genderList[genderIndex].name:'请选择性别')+''}}</text><text class="picker-arrow">▼</text></view></picker></view><view class="form-item"><text class="label">年龄</text><input class="input" type="number" placeholder="请输入年龄" maxlength="3" data-event-opts="{{[['input',[['__set_model',['$0','age','$event',[]],['formData']]]]]}}" value="{{formData.age}}" bindinput="__e"/></view><view class="form-item"><text class="label">选择小区</text><picker value="{{communityIndex}}" range="{{communityList}}" range-key="name" disabled="{{$root.g0===0}}" data-event-opts="{{[['change',[['onCommunityChange',['$event']]]]]}}" bindchange="__e"><view class="picker-content"><text class="{{['picker-text',(!selectedCommunity)?'placeholder':'']}}">{{''+(selectedCommunity?selectedCommunity.name:'请选择小区')+''}}</text><text class="picker-arrow">▼</text></view></picker></view><view class="form-item"><text class="label">选择楼栋</text><picker value="{{buildingIndex}}" range="{{buildingList}}" range-key="name" disabled="{{$root.g1===0}}" data-event-opts="{{[['change',[['onBuildingChange',['$event']]]]]}}" bindchange="__e"><view class="picker-content"><text class="{{['picker-text',(!selectedBuilding)?'placeholder':'']}}">{{''+(selectedBuilding?selectedBuilding.name:'请选择楼栋')+''}}</text><text class="picker-arrow">▼</text></view></picker></view><view class="form-item"><text class="label">选择房间</text><picker value="{{roomIndex}}" range="{{roomList}}" range-key="roomNumber" disabled="{{$root.g2===0}}" data-event-opts="{{[['change',[['onRoomChange',['$event']]]]]}}" bindchange="__e"><view class="picker-content"><text class="{{['picker-text',(!selectedRoom)?'placeholder':'']}}">{{''+(selectedRoom?selectedRoom.roomNumber:'请选择房间')+''}}</text><text class="picker-arrow">▼</text></view></picker></view><view class="form-item"><text class="label">业主关系</text><picker value="{{relationIndex}}" range="{{currentRelationList}}" range-key="name" disabled="{{$root.g3===0}}" data-event-opts="{{[['change',[['onRelationChange',['$event']]]]]}}" bindchange="__e"><view class="picker-content"><text class="{{['picker-text',(!selectedRelation)?'placeholder':'']}}">{{''+(selectedRelation?selectedRelation.name:formData.roomId?'请选择业主关系':'请先选择房间')+''}}</text><text class="picker-arrow">▼</text></view></picker><block wx:if="{{!currentRoomHasOwner&&formData.roomId}}"><text class="hint-text">该房间暂无业主，请先以业主身份绑定</text></block></view><view class="form-item"><text class="label">车牌号（选填）</text><view class="plate-list"><block wx:for="{{plateNumbers}}" wx:for-item="plate" wx:for-index="index" wx:key="index"><view class="plate-row"><input class="input plate-input" placeholder="请输入车牌号" maxlength="10" data-event-opts="{{[['input',[['__set_model',['$0',index,'$event',[]],['plateNumbers']]]]]}}" value="{{plateNumbers[index]}}" bindinput="__e"/><block wx:if="{{$root.g4>1}}"><view data-event-opts="{{[['tap',[['removePlate',[index]]]]]}}" class="plate-remove" bindtap="__e"><text class="remove-text">删除</text></view></block></view></block></view><block wx:if="{{$root.g5<5}}"><view data-event-opts="{{[['tap',[['addPlate',['$event']]]]]}}" class="add-plate" bindtap="__e"><text class="add-plate-text">+ 添加车牌</text></view></block></view><view class="form-item"><text class="label">备注</text><textarea class="textarea" placeholder="请输入备注信息（选填）" maxlength="200" data-event-opts="{{[['input',[['__set_model',['$0','remark','$event',[]],['formData']]]]]}}" value="{{formData.remark}}" bindinput="__e"></textarea></view><button class="{{['submit-btn',(!canSubmit)?'disabled':'']}}" disabled="{{!canSubmit}}" data-event-opts="{{[['tap',[['submitBinding',['$event']]]]]}}" bindtap="__e"> 提交绑定 </button></view></view></view>